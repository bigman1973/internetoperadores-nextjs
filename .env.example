# Base de datos
DATABASE_URL="postgresql://usuario:password@host:port/database"

# NextAuth
NEXTAUTH_URL="https://www.internetoperadores.com"
NEXTAUTH_SECRET="tu_secret_super_seguro_aqui"

# Azure AD (Microsoft) Authentication
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret
AZURE_AD_TENANT_ID=your_tenant_id

# HubSpot CRM
HUBSPOT_API_KEY=pat-eu1-xxxx

# Vivid Business Acquiring (Pagos con tarjeta y SEPA)
VIVID_CLIENT_ID=your_vivid_client_id
VIVID_SECRET=your_vivid_secret

# Triple-A (Pagos con stablecoins USDC/EURC)
TRIPLE_A_CLIENT_ID=your_triple_a_client_id
TRIPLE_A_CLIENT_SECRET=your_triple_a_client_secret
TRIPLE_A_MERCHANT_KEY=your_triple_a_merchant_key

# Email (para notificaciones - opcional por ahora)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@internetoperadores.com"
SMTP_PASS="password"
SMTP_FROM="Internet Operadores <noreply@internetoperadores.com>"
