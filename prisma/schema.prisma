  @@map("importaciones_extracto")
}

model ContratoDraxton {
  id                    String   @id @default(uuid())
  codigoContrato        String?  @unique @map("codigo_contrato")
  titulo                String
  tipo                  String   @default("Servicios Internet")
  fechaFirma            DateTime? @map("fecha_firma") @db.Date
  fechaInicio           DateTime? @map("fecha_inicio") @db.Date
  fechaFin              DateTime? @map("fecha_fin") @db.Date
  fechaInicioServicio   DateTime? @map("fecha_inicio_servicio") @db.Date
  permanenciaMeses      Int?     @map("permanencia_meses")
  prorrogaAutomatica    Boolean  @default(true) @map("prorroga_automatica")
  plazoProrroga         String?  @map("plazo_prorroga")
  importeMensual        Decimal? @map("importe_mensual") @db.Decimal(12, 2)
  importeAnual          Decimal? @map("importe_anual") @db.Decimal(12, 2)
  formaPago             String?  @map("forma_pago")
  estado                String   @default("Activo")
  contactoCliente       String?  @map("contacto_cliente")
  contactoProveedor     String?  @map("contacto_proveedor")
  notas                 String?
  condicionesEspeciales String?  @map("condiciones_especiales")
  serviciosJson         Json?    @map("servicios_json")
  diaFacturacion        Int?     @map("dia_facturacion")
  mesFacturacion        String?  @map("mes_facturacion")
  documentoUrl          String?  @map("documento_url")
  documentoNombre       String?  @map("documento_nombre")
  // Campos para contratos de mantenimiento IT
  modalidadContrato     String?  @map("modalidad_contrato") // "horas" o "recurso"
  horasContratadas      Float?   @map("horas_contratadas") // Horas mensuales contratadas
  nivelContratado       Int?     @map("nivel_contratado") // 1, 2 o 3
  precioHoraContrato    Decimal? @map("precio_hora_contrato") @db.Decimal(10, 2) // Calculado: importeMensual / horasContratadas
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  clienteFacturacionId  Int?     @map("cliente_facturacion_id")
  clienteFacturacion    ClienteWeb? @relation(fields: [clienteFacturacionId], references: [id])
  contratosProveedor    ContratoProveedorDraxton[]
  facturasVinculadas    FacturaContratoDraxton[]
  personalAsignado      PersonalContratoDraxton[]
  proyectos             ProyectoContratoDraxton[]

  @@map("contratos_draxton")
}

model ContratoProveedorDraxton {
  id                    String   @id @default(uuid())
  codigoContrato        String?  @unique @map("codigo_contrato")
  contratoClienteId     String   @map("contrato_cliente_id")
  contratoCliente       ContratoDraxton @relation(fields: [contratoClienteId], references: [id], onDelete: Cascade)
  proveedor             String
  cifProveedor          String?  @map("cif_proveedor")
  titulo                String
  tipo                  String   @default("Servicios Internet")
  fechaFirma            DateTime? @map("fecha_firma") @db.Date
  fechaInicio           DateTime? @map("fecha_inicio") @db.Date
  fechaFin              DateTime? @map("fecha_fin") @db.Date
  fechaInicioServicio   DateTime? @map("fecha_inicio_servicio") @db.Date
  permanenciaMeses      Int?     @map("permanencia_meses")
  prorrogaAutomatica    Boolean  @default(true) @map("prorroga_automatica")
  plazoProrroga         String?  @map("plazo_prorroga")
  importeMensual        Decimal? @map("importe_mensual") @db.Decimal(12, 2)
  importeAnual          Decimal? @map("importe_anual") @db.Decimal(12, 2)
  formaPago             String?  @map("forma_pago")
  estado                String   @default("Activo")
  contactoProveedor     String?  @map("contacto_proveedor")
  notas                 String?
  condicionesEspeciales String?  @map("condiciones_especiales")
  serviciosJson         Json?    @map("servicios_json")
  documentoUrl          String?  @map("documento_url")
  documentoNombre       String?  @map("documento_nombre")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("contratos_proveedor_draxton")
}

model PersonalContratoDraxton {
  id                    String   @id @default(uuid())
  contratoDraxtonId     String   @map("contrato_draxton_id")
  empleadoId            String   @map("empleado_id")
  porcentajeDedicacion  Float    @default(100) @map("porcentaje_dedicacion") // % libre (1-100)
  nivelTecnico          Int?     @map("nivel_tecnico") // 1, 2 o 3 - multiplicador de consumo de horas
  rol                   String?  // Responsable, Técnico, Soporte, etc.
  funciones             String?  // Descripción de funciones del puesto
  fechaInicio           DateTime? @map("fecha_inicio") @db.Date
  fechaFin              DateTime? @map("fecha_fin") @db.Date
  activo                Boolean  @default(true)
  notas                 String?
  // Relaciones
  contratoDraxton       ContratoDraxton @relation(fields: [contratoDraxtonId], references: [id], onDelete: Cascade)
  empleado              Empleado @relation("PersonalContratoDraxton", fields: [empleadoId], references: [id])
  tareas                PersonalContratoTarea[]
  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([contratoDraxtonId, empleadoId])
  @@index([contratoDraxtonId])
  @@index([empleadoId])
  @@map("personal_contratos_draxton")
}

model PersonalContratoTarea {
  id                    String   @id @default(uuid())
  personalContratoId    String   @map("personal_contrato_id")
  personalContrato      PersonalContratoDraxton @relation(fields: [personalContratoId], references: [id], onDelete: Cascade)
  descripcion           String
  completada            Boolean  @default(false)
  orden                 Int      @default(0)
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([personalContratoId])
  @@map("personal_contrato_tareas")
}

model FacturaContratoDraxton {
  id                    String   @id @default(uuid())
  facturaId             Int      @map("factura_id")
  contratoDraxtonId     String   @map("contrato_draxton_id")
  empresaGrupoDraxtonId String?  @map("empresa_grupo_draxton_id")
  servicioIndex         Int?     @map("servicio_index")  // Índice del servicio en serviciosJson (null = sin asignar)
  importeAsignado       Decimal  @map("importe_asignado") @db.Decimal(12, 2)
  estado                String   @default("auto") @map("estado")  // auto, pendiente, asignada
  tipoFacturacion       String   @default("mensualidad") @map("tipo_facturacion")  // mensualidad, adicional
  auto                  Boolean  @default(true)  // true = vinculación automática, false = manual
  notas                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  factura               Factura  @relation(fields: [facturaId], references: [id])
  contratoDraxton       ContratoDraxton @relation(fields: [contratoDraxtonId], references: [id], onDelete: Cascade)

  @@unique([facturaId, contratoDraxtonId])
  @@index([contratoDraxtonId])
  @@index([facturaId])
  @@index([servicioIndex])
  @@map("facturas_contratos_draxton")
}

model ProyectoContratoDraxton {
  id                    String   @id @default(uuid())
  contratoDraxtonId     String   @map("contrato_draxton_id")
  responsableId         String?  @map("responsable_id") // Empleado responsable
  titulo                String
  descripcion           String?  @db.Text
  categoria             String   @default("proyecto") // proyecto, mejora_ejecutada, propuesta_futura
  estado                String   @default("en_curso") // planificado, en_curso, completado, pausado
  impacto               String?  @db.Text // Descripción del impacto operativo
  ahorroEstimado        Decimal? @map("ahorro_estimado") @db.Decimal(12, 2)
  fechaInicio           DateTime? @map("fecha_inicio") @db.Date
  fechaFinPrevista      DateTime? @map("fecha_fin_prevista") @db.Date
  fechaFinReal          DateTime? @map("fecha_fin_real") @db.Date
  prioridad             String   @default("media") // alta, media, baja
  orden                 Int      @default(0)
  activo                Boolean  @default(true)
  // Relaciones
  contratoDraxton       ContratoDraxton @relation(fields: [contratoDraxtonId], references: [id], onDelete: Cascade)
  responsable           Empleado? @relation("ProyectoResponsable", fields: [responsableId], references: [id])
  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([contratoDraxtonId])
  @@index([responsableId])
  @@index([categoria])
  @@index([estado])
  @@map("proyectos_contratos_draxton")
}

model EmpresaGrupoDraxton {
  id            String     @id @default(uuid())
  nombre        String
  cif           String?    @unique
  direccion     String?
  poblacion     String?
  provincia     String?
  contacto      String?
  email         String?
  telefono      String?
  activa        Boolean    @default(true)
  notas         String?
  clienteWebId  Int?       @unique @map("cliente_web_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("empresas_grupo_draxton")
}


// =============================================
// MÓDULO GUARDIAS DRAXTON
// =============================================

// Configuración del contrato de guardias
model GuardiaConfig {
  id                    String   @id @default(uuid())
  contratoId            String   @unique @map("contrato_id") // FK al ContratoDraxton tipo Guardias
  margenDesplazamiento  Float?   @map("margen_desplazamiento") // % margen sobre coste desplazamiento
  precioHoraCliente     Float?   @map("precio_hora_cliente") // Precio/hora que se cobra a Draxton
  costeHoraTecnico      Float?   @map("coste_hora_tecnico") // Coste/hora del técnico en desplazamiento
  costeDesplazFijo      Float?   @map("coste_desplaz_fijo") // Coste fijo por desplazamiento (km, gasolina, etc.)
  precioDesplazCliente  Float?   @map("precio_desplaz_cliente") // Precio fijo desplazamiento que se cobra a Draxton
  observaciones         String?  @db.Text
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relaciones
  tecnicos              GuardiaTecnico[]
  tarifas               GuardiaTarifa[]
  asignaciones          GuardiaAsignacion[]
  incidencias           GuardiaIncidencia[]

  @@map("guardia_config")
}

// Técnicos asignados al contrato de guardias
model GuardiaTecnico {
  id              String         @id @default(uuid())
  configId        String         @map("config_id")
  empleadoId      String         @map("empleado_id")
  nivel           Int            @default(1) // 1, 2, 3
  activo          Boolean        @default(true)
  fechaAlta       DateTime       @map("fecha_alta") @db.Date
  fechaBaja       DateTime?      @map("fecha_baja") @db.Date
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relaciones
  config          GuardiaConfig  @relation(fields: [configId], references: [id])
  empleado        Empleado       @relation(fields: [empleadoId], references: [id])
  asignaciones    GuardiaAsignacion[]
  historicoNiveles GuardiaTecnicoHistorico[]

  @@unique([configId, empleadoId])
  @@map("guardia_tecnicos")
}

// Histórico de cambios de nivel de un técnico
model GuardiaTecnicoHistorico {
  id              String         @id @default(uuid())
  tecnicoId       String         @map("tecnico_id")
  nivelAnterior   Int            @map("nivel_anterior")
  nivelNuevo      Int            @map("nivel_nuevo")
  fechaCambio     DateTime       @map("fecha_cambio") @db.Date
  motivo          String?        // Motivo del cambio (opcional)
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relaciones
  tecnico         GuardiaTecnico @relation(fields: [tecnicoId], references: [id])

  @@map("guardia_tecnicos_historico")
}

// Tarifas por nivel (con histórico de cambios)
model GuardiaTarifa {
  id              String         @id @default(uuid())
  configId        String         @map("config_id")
  nivel           Int            // 1, 2, 3
  importeSemana   Float          @map("importe_semana") // Coste por semana de guardia
  fechaDesde      DateTime       @map("fecha_desde") @db.Date
  fechaHasta      DateTime?      @map("fecha_hasta") @db.Date // null = vigente
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relaciones
  config          GuardiaConfig  @relation(fields: [configId], references: [id])

  @@index([configId, nivel, fechaDesde])
  @@map("guardia_tarifas")
}

// Asignación semanal de técnico de guardia
model GuardiaAsignacion {
  id              String         @id @default(uuid())
  configId        String         @map("config_id")
  tecnicoId       String         @map("tecnico_id")
  semanaInicio    DateTime       @map("semana_inicio") @db.Date // Lunes de la semana
  semanaFin       DateTime       @map("semana_fin") @db.Date    // Domingo de la semana
  importeSemana   Float?         @map("importe_semana") // Coste de esa semana (snapshot)
  notas           String?
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relaciones
  config          GuardiaConfig  @relation(fields: [configId], references: [id])
  tecnico         GuardiaTecnico @relation(fields: [tecnicoId], references: [id])
  incidencias     GuardiaIncidencia[]

  @@unique([configId, semanaInicio])
  @@map("guardia_asignaciones")
}

// Registro de incidencias durante guardias
model GuardiaIncidencia {
  id                    String         @id @default(uuid())
  configId              String         @map("config_id")
  asignacionId          String?        @map("asignacion_id") // Semana en que ocurrió
  // Datos de la incidencia
  fechaHora             DateTime       @map("fecha_hora")
  resumen               String         @db.Text
  descripcion           String?        @db.Text
  avisadoPor            String         @map("avisado_por") // Quién dio el aviso
  departamento          String?        // Departamento que avisa
  zonaAfectada          String?        @map("zona_afectada")
  urgencia              String         @default("inmediata") // "inmediata" | "puede_esperar"
  // Resolución
  estado                String         @default("abierta") // "abierta" | "en_curso" | "resuelta"
  tipoResolucion        String?        @map("tipo_resolucion") // "remoto" | "desplazamiento"
  fechaResolucion       DateTime?      @map("fecha_resolucion")
  detalleResolucion     String?        @map("detalle_resolucion") @db.Text
  // Desplazamiento (si aplica)
  horasDesplazamiento   Float?         @map("horas_desplazamiento")
  costeDesplazamiento   Float?         @map("coste_desplazamiento") // Coste real (km, peajes, etc.)
  importeClienteDesp    Float?         @map("importe_cliente_desp") // Lo que se cobra a Draxton
  // Escalado
  escaladoInterno       Boolean        @default(false) @map("escalado_interno")
  escaladoCliente       Boolean        @default(false) @map("escalado_cliente")
  detalleEscalado       String?        @map("detalle_escalado") @db.Text
  // Timestamps
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  // Relaciones
  config                GuardiaConfig  @relation(fields: [configId], references: [id])
  asignacion            GuardiaAsignacion? @relation(fields: [asignacionId], references: [id])

  @@index([configId, fechaHora])
  @@index([estado])
  @@map("guardia_incidencias")
}

// ==========================================
// PERMISOS GRANULARES POR ÁREA
// ==========================================

model PermisoArea {
  id              String           @id @default(cuid())
  codigo          String           @unique // ej: "admin.ggcc.draxton.contratos"
  nombre          String           // ej: "GGCC > Draxton > Contratos"
  descripcion     String?
  padre           String?          // código del padre, ej: "admin.ggcc.draxton"
  orden           Int              @default(0)
  activo          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  permisos        PermisoUsuario[]

  @@index([padre])
  @@index([codigo])
  @@map("permiso_areas")
}

model PermisoUsuario {
  id              String       @id @default(cuid())
  usuarioId       Int          @map("usuario_id")
  areaId          String       @map("area_id")
  lectura         Boolean      @default(false)
  escritura       Boolean      @default(false)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  usuario         UsuarioAdmin @relation(fields: [usuarioId], references: [id])
  area            PermisoArea  @relation(fields: [areaId], references: [id])

  @@unique([usuarioId, areaId])
  @@index([usuarioId])
  @@index([areaId])
  @@map("permiso_usuarios")
}
