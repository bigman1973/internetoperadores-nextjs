  // Estado del alta
  estado                EstadoAlta          @default(FORMULARIO_PENDIENTE)
  
  // Observaciones
  observaciones         String?
  
  // Token para acceso del cliente (completar documentación)
  token                 String              @unique @default(uuid())
  
  // Contrato generado
  contratoPdfUrl        String?             @map("contrato_pdf_url")
  contratoFirmado       Boolean             @default(false) @map("contrato_firmado")
  
  // Documentos
  documentos            DocumentoAlta[]
  
  // Historial de envíos de contrato
  enviosContrato        EnvioContrato[]
  
  // Timestamps
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  completadoAt          DateTime?           @map("completado_at")
  
  @@index([estado])
  @@index([tipoCliente])
  @@index([email])
  @@index([token])
  @@index([createdAt])
  @@map("altas_servicio")
}

model DocumentoAlta {
