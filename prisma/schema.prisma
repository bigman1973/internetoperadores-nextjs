model DesarrolloHistorial {
  id          Int       @id @default(autoincrement())
  titulo      String
  descripcion String
  tipo        String    @db.VarChar(50) // feat, fix, refactor, perf, style, ui
  estado      String    @db.VarChar(50) // completado, en_progreso, etc.
  autor       String?   @db.VarChar(100)
  commitHash  String?   @map("commit_hash") @db.VarChar(100)
  rama        String?   @db.VarChar(100)
  fecha       DateTime  @default(now())

  @@map("desarrollo_historial")
}

model ImportacionExtracto {
  id              String   @id @default(uuid())
  cuentaId        String   @map("cuenta_id")
  cuenta          CuentaBancaria @relation(fields: [cuentaId], references: [id])
  nombreArchivo   String   @map("nombre_archivo")
  archivoUrl      String?  @map("archivo_url") // URL en Vercel Blob
  formato         String   // santander, caixabank, bbva, etc.
  movImportados   Int      @map("mov_importados")
  movDuplicados   Int      @default(0) @map("mov_duplicados")
  fechaPrimerMov  DateTime? @map("fecha_primer_mov")
  fechaUltimoMov  DateTime? @map("fecha_ultimo_mov")
  createdAt       DateTime @default(now()) @map("created_at")
