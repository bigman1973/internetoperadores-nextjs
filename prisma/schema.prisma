model SyncLog {
  id          String   @id @default(uuid())
  fuente      String
  tipo        String
  registros   Int      @default(0)
  estado      String
  mensaje     String?
  ejecutadoAt DateTime @default(now()) @map("ejecutado_at")

  @@index([fuente, ejecutadoAt])
  @@map("sync_logs")
}

model SaldoVacaciones {
  id              String    @id @default(uuid())
  empleadoId      String?   @map("empleado_id")
  empleadoNombre  String    @map("empleado_nombre")
  hrlogEmpleadoId Int?      @map("hrlog_empleado_id")
  anio            Int       @default(2026)
  diasConvenio    Int       @default(22) @map("dias_convenio")
  diasBolsa       Int       @default(0) @map("dias_bolsa")
  diasAntiguedad  Int       @default(0) @map("dias_antiguedad")
  diasTotal       Int       @default(22) @map("dias_total")
  diasDisfrutadas Int       @default(0) @map("dias_disfrutadas")
  diasAprobadas   Int       @default(0) @map("dias_aprobadas")
  diasEnTramite   Int       @default(0) @map("dias_en_tramite")
  saldoActual     Int       @default(0) @map("saldo_actual")
  empleado        Empleado? @relation(fields: [empleadoId], references: [id])
  syncAt          DateTime  @default(now()) @map("sync_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([empleadoNombre, anio])
  @@index([empleadoId])
  @@index([anio])
  @@map("saldo_vacaciones")
}

// ============================================================
// MÓDULO DE CONCILIACIÓN DE REMESAS
// ============================================================

enum EstadoConciliacion {
  CONCILIADA
  PENDIENTE
  DIFERENCIA
}

enum EstadoDevolucion {
  PENDIENTE
  COBRADO_TRANSFERENCIA
  COBRADO_PARCIAL
  INCOBRABLE
}

model ConciliacionRemesa {
  id                    String              @id @default(uuid())
  remesaId              Int                 @map("remesa_id")
  remesa                Remesa              @relation(fields: [remesaId], references: [id])
  movimientoBancarioId  String?             @unique @map("movimiento_bancario_id")
  movimiento            MovimientoBancario? @relation("ConciliacionMovimiento", fields: [movimientoBancarioId], references: [id])
  importeRemesa         Decimal             @map("importe_remesa") @db.Decimal(10, 2)
  importeMovimiento     Decimal?            @map("importe_movimiento") @db.Decimal(10, 2)
  importeCobrado        Decimal?            @map("importe_cobrado") @db.Decimal(10, 2)
  pendienteAbonar       Decimal?            @map("pendiente_abonar") @db.Decimal(10, 2)
  diferencia            Decimal?            @db.Decimal(10, 2)
  estado                EstadoConciliacion  @default(PENDIENTE)
  fechaConciliacion     DateTime?           @map("fecha_conciliacion")
  notas                 String?
  // Datos del PDF del banco
  recibosRemesados      Int?                @map("recibos_remesados")
  recibosCobrados       Int?                @map("recibos_cobrados")
  rechazos              Int?                @map("rechazos")
  referenciaRemesaBanco String?             @map("referencia_remesa_banco")
  // Sub-remesas del banco (por fecha de vencimiento)
  subRemesas            SubRemesaBanco[]
  // Timestamps
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([remesaId])
  @@index([estado])
  @@index([fechaConciliacion])
  @@map("conciliaciones_remesas")
}

model SubRemesaBanco {
  id                    String              @id @default(uuid())
  conciliacionId        String              @map("conciliacion_id")
  conciliacion          ConciliacionRemesa  @relation(fields: [conciliacionId], references: [id], onDelete: Cascade)
  referenciaRemesa      String              @unique @map("referencia_remesa")
  fechaVencimiento      DateTime            @map("fecha_vencimiento") @db.Date
  numRecibos            Int                 @map("num_recibos")
  importe               Decimal             @db.Decimal(10, 2)
  movimientoBancarioId  String?             @map("movimiento_bancario_id")
  movimiento            MovimientoBancario? @relation("SubRemesaMovimiento", fields: [movimientoBancarioId], references: [id])
  cobrado               Boolean             @default(false)
  createdAt             DateTime            @default(now()) @map("created_at")

  @@index([conciliacionId])
  @@index([movimientoBancarioId])
  @@map("sub_remesas_banco")
}

model DevolucionRemesa {
  id                    String              @id @default(uuid())
  remesaId              Int?                @map("remesa_id")
  remesa                Remesa?             @relation(fields: [remesaId], references: [id])
  facturaId             Int?                @map("factura_id")
  factura               Factura?            @relation(fields: [facturaId], references: [id])
  movimientoBancarioId  String?             @map("movimiento_bancario_id")
  movimiento            MovimientoBancario? @relation("DevolucionMovimiento", fields: [movimientoBancarioId], references: [id])
  // Datos del PDF banco / Excel DevSEPA
  numeroFactura         String              @map("numero_factura") // Ej: CLL26/137
  referenciaRemesa      String?             @map("referencia_remesa") // Ej: CLL137
  referenciaExterna     String?             @map("referencia_externa") // Ej: CLL986 (del PDF banco)
  nombreCliente         String              @map("nombre_cliente")
  importe               Decimal             @db.Decimal(10, 2)
  motivo                String?             // Motivo de la devolución
  motivoBanco           String?             @map("motivo_banco") // Motivo exacto del banco (Fondos insuficientes, etc.)
  comisionBanco         Decimal?            @map("comision_banco") @db.Decimal(10, 2) // Comisión por devolución
  fechaDevolucion       DateTime            @map("fecha_devolucion") @db.Date
  // Estado de cobro posterior
  estado                EstadoDevolucion    @default(PENDIENTE)
  movimientoCobroId     String?             @map("movimiento_cobro_id") // Movimiento de transferencia posterior
  movimientoCobro       MovimientoBancario? @relation("DevolucionCobro", fields: [movimientoCobroId], references: [id])
  fechaCobro            DateTime?           @map("fecha_cobro") @db.Date
  importeCobrado        Decimal?            @map("importe_cobrado") @db.Decimal(10, 2)
  // Origen
  archivoOrigen         String?             @map("archivo_origen") // Nombre del Excel DevSEPA
  mesDevolucion         Int?                @map("mes_devolucion") // 1-12
  anioDevolucion        Int?                @map("anio_devolucion") // 2026
  // Timestamps
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([remesaId])
  @@index([facturaId])
  @@index([estado])
  @@index([fechaDevolucion])
  @@index([anioDevolucion, mesDevolucion])
  @@map("devoluciones_remesas")
}

// ============================================================
// DATOS FISCALES (Proveedores, Personal, AAPP)
// ============================================================

enum TipoEntidadFiscal {
  PROVEEDOR
  CLIENTE
  PERSONAL
  AAPP
}

model EntidadFiscal {
  id                String   @id @default(uuid())
  tipo              TipoEntidadFiscal
  // Datos fiscales
  razonSocial       String   @map("razon_social") // Nombre fiscal / Razón social
  nombreComercial   String?  @map("nombre_comercial") // Nombre comercial (si difiere)
  nifCif            String?  @map("nif_cif") // NIF/CIF
  direccionFiscal   String?  @map("direccion_fiscal")
  codigoPostal      String?  @map("codigo_postal")
  poblacion         String?  
  provincia         String?  
  pais              String?  @default("ES")
  // Contacto
  emailFacturacion  String?  @map("email_facturacion")
  emailGeneral      String?  @map("email_general")
  telefono          String?  
  personaContacto   String?  @map("persona_contacto")
  // Contabilidad A3
  cuentaContableA3  String?  @map("cuenta_contable_a3") // 400XXXX proveedores, 465XXXX personal, 475XXXX AAPP
  // Clasificación interna
  categoriaInterna  String?  @map("categoria_interna") // Operadora, Estructura, etc.
  subcategoria      String?  // Más detalle
  // Condiciones comerciales
  formaPago         String?  @map("forma_pago") // domiciliacion, transferencia, confirming, etc.
  diaPago           Int?     @map("dia_pago") // Día habitual de pago (1-31)
  plazoVencimiento  Int?     @map("plazo_vencimiento") // Días desde factura hasta vencimiento
  iban              String?  // Cuenta bancaria
  // Patrones de concepto bancario (para auto-identificar en movimientos)
  patronesBancarios String?  @map("patrones_bancarios") // JSON array de strings regex
  // Estado
  activo            Boolean  @default(true)
  notas             String?  
  // Relaciones
  movimientos       MovimientoBancario[] @relation("MovimientoProveedor")
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tipo])
  @@index([nifCif])
  @@index([razonSocial])
  @@index([categoriaInterna])
  @@map("entidades_fiscales")
}

// ============================================================
