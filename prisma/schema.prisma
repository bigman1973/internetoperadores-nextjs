// =============================================
// MÓDULO FINANCIERO - Control de Tesorería
// =============================================

model CuentaBancaria {
  id          String   @id @default(uuid())
  banco       String   // Santander, CaixaBank, BBVA, Caixa Guissona, Vivid, Wise
  iban        String   @unique
  alias       String?  // Nombre corto para identificar
  activa      Boolean  @default(true)
  saldoActual Float?   @map("saldo_actual")
  fechaSaldo  DateTime? @map("fecha_saldo")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  movimientos MovimientoBancario[]
  importaciones ImportacionExtracto[]

  @@map("cuentas_bancarias")
}

model MovimientoBancario {
  id              String   @id @default(uuid())
  cuentaId        String   @map("cuenta_id")
  cuenta          CuentaBancaria @relation(fields: [cuentaId], references: [id])
  fechaOperacion  DateTime @map("fecha_operacion")
  fechaValor      DateTime @map("fecha_valor")
  concepto        String
  importe         Float
  saldo           Float?
  referencia      String?
  codigoOperacion String?  @map("codigo_operacion")
  infoAdicional   String?  @map("info_adicional")
  tercero         String?  // Destinatario (salidas) u Ordenante (entradas) extraído del extracto
  // Categorización
  categoria       String?  // Imputación: Estructura, Operadora, Draxton, etc.
  tipoPago        String?  @map("tipo_pago") // Factura, IVA, SS, Nómina, etc.
  metodoPago      String?  @map("metodo_pago") // Domiciliación, Transferencia, Débito, etc.
  esRecurrente    Boolean  @default(false) @map("es_recurrente")
  // Conciliación
  conciliado      Boolean  @default(false)
  facturaId       String?  @map("factura_id")
  factura         FacturaRecibida? @relation(fields: [facturaId], references: [id])
  gastoId         String?  @map("gasto_id")
  gasto           Gasto?   @relation(fields: [gastoId], references: [id])
  // Estados especiales de conciliación
  pendienteFactura  Boolean  @default(false) @map("pendiente_factura") // Factura pendiente de recibir/reclamar
  pagoACuentaVola   Boolean  @default(false) @map("pago_a_cuenta_vola") // Pago a cuenta de Vola
  facturaEmitidaId  String?  @map("factura_emitida_id") // Vinculación con factura emitida (ingresos)
  facturaEmitida    FacturaEmitida? @relation(fields: [facturaEmitidaId], references: [id])
  notaConciliacion  String?  @map("nota_conciliacion") // Nota libre del usuario
  tipoDocumento     String?  @map("tipo_documento") // 'factura' o 'ticket'
  documentoRecibido Boolean? @map("documento_recibido") // null=no aplica, true=tenemos doc, false=falta doc
  // Entrega a cuenta empleado
  entregaACuentaEmpleadoId  String?  @map("entrega_a_cuenta_empleado_id")
  entregaACuentaEmpleado    Empleado? @relation("EntregasCuentaEmpleado", fields: [entregaACuentaEmpleadoId], references: [id])
  tipoEntrega               String?  @map("tipo_entrega") // 'coste_empresa' o 'anticipo'
  // Vinculación con nómina
  nominaId                  String?  @map("nomina_id")
  nomina                    Nomina?  @relation(fields: [nominaId], references: [id])
  // Vinculación con entidad fiscal (proveedor/AAPP)
  entidadFiscalId           String?  @map("entidad_fiscal_id")
  entidadFiscal             EntidadFiscal? @relation("MovimientoProveedor", fields: [entidadFiscalId], references: [id])
  // Traspaso entre cuentas propias
  traspasoRelacionadoId     String?  @map("traspaso_relacionado_id")
  // Importación
  hashUnico       String   @unique @map("hash_unico") // Para evitar duplicados
  origenArchivo   String?  @map("origen_archivo")
  createdAt       DateTime @default(now()) @map("created_at")
  // Relaciones conciliación remesas
  conciliacionRemesa    ConciliacionRemesa?  @relation("ConciliacionMovimiento")
  subRemesasBanco       SubRemesaBanco[]     @relation("SubRemesaMovimiento")
  devolucionesRemesa    DevolucionRemesa[]   @relation("DevolucionMovimiento")
  devolucionesCobro     DevolucionRemesa[]   @relation("DevolucionCobro")

  @@index([cuentaId, fechaOperacion])
  @@index([conciliado])
  @@index([categoria])
  @@map("movimientos_bancarios")
}

model FacturaRecibida {
  id              String   @id @default(uuid())
  proveedor       String
  cif             String?
  domicilioProveedor String? @map("domicilio_proveedor") // Dirección fiscal del proveedor
  numFactura      String?  @map("num_factura")
  fecha           DateTime
  base            Float    // Base imponible
  tipoIva         Float    @default(21) @map("tipo_iva") // % IVA
  importeIva      Float    @map("importe_iva")
  tipoIrpf        Float    @default(0) @map("tipo_irpf") // % IRPF retención
  importeIrpf     Float    @default(0) @map("importe_irpf")
  total           Float
  concepto        String?
  // Clasificación
  estado          EstadoFactura @default(PENDIENTE_REVISION)
  imputacion      String?  // Estructura, Operadora, Draxton, etc.
  clienteImputado String?  @map("cliente_imputado") // Para analítica de rentabilidad
  departamento    String?
  // Archivo
  archivoUrl      String?  @map("archivo_url")
  archivoOneDrive String?  @map("archivo_onedrive") // Ruta en OneDrive
  oneDriveItemId  String?  @unique @map("onedrive_item_id") // ID del item en OneDrive
  carpetaOrigen   String?  @map("carpeta_origen") // Pendiente, Trimestre 1, etc.
  // OCR
  ocrCompletado   Boolean  @default(false) @map("ocr_completado")
  ocrConfianza    Float?   @map("ocr_confianza") // 0-1 confianza del OCR
  datosOcrRaw     String?  @map("datos_ocr_raw") // JSON con datos extraídos
  lineasDetalle   String?  @map("lineas_detalle") // JSON [{descripcion, cliente, precio, iva, importe}]
  // Internacional
  esInternacional Boolean  @default(false) @map("es_internacional") // Factura intracomunitaria/internacional
  paisOrigen      String?  @map("pais_origen") // Código ISO del país del emisor si es internacional
  // Imputación a ventas
  imputadoAVentas Boolean  @default(false) @map("imputado_a_ventas") // Si ya se imputó a clientes
  fechaImputacion DateTime? @map("fecha_imputacion") // Cuándo se imputó
  // Pago
  formaPago       String?  @map("forma_pago") // transferencia, confirming, domiciliacion, etc.
  confirmingProveedor String? @map("confirming_proveedor") // Draxton, etc. (para conciliación)
  // Deducibilidad
  telefonoServicio String?  @map("telefono_servicio") // Teléfono del servicio (Telefónica fijas)
  fechaVencimiento DateTime? @map("fecha_vencimiento") // Fecha vencimiento de pago
  deducibleIva    Boolean  @default(true) @map("deducible_iva")
  // Confirming
  totalConfirming  Float?   @map("total_confirming") // Total del confirming (editable)
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  movimientos     MovimientoBancario[]
  confirmingLineas ConfirmingLinea[]

  @@index([estado])
  @@index([proveedor])
  @@index([fecha])
  @@index([imputacion])
  @@map("facturas_recibidas")
}

model ConfirmingLinea {
  id               String   @id @default(uuid())
  confirmingId     String   @map("confirming_id")
  numFactura       String   @map("num_factura")
  importe          Float    @default(0)
  facturaEmitidaId String?  @map("factura_emitida_id")
  notas            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  confirming       FacturaRecibida  @relation(fields: [confirmingId], references: [id], onDelete: Cascade)
  facturaEmitida   FacturaEmitida?  @relation(fields: [facturaEmitidaId], references: [id], onDelete: SetNull)

  @@index([confirmingId])
  @@index([facturaEmitidaId])
  @@map("confirming_lineas")
}

model Gasto {
  id              String   @id @default(uuid())
  concepto        String
  importe         Float
  fecha           DateTime
  tipo            TipoGasto @default(GASTO_GENERAL)
  // Clasificación
  departamento    String?
  clienteImputado String?  @map("cliente_imputado")
  imputacion      String?
  empleado        String?  // Quién generó el gasto (nombre)
  empleadoId      String?  @map("empleado_id") // ID del usuario que subió el ticket
  // Asignación cliente/proyecto
  clienteNombre   String?  @map("cliente_nombre") // Cliente al que pertenece el gasto
  proyecto        String?  // Proyecto (texto libre)
  // Método de pago del empleado
  metodoPago      MetodoPagoGasto @default(TARJETA_EMPRESA) @map("metodo_pago")
  // Aprobación
  motivoRechazo   String?  @map("motivo_rechazo")
  aprobadoPor     String?  @map("aprobado_por") // Email del aprobador
  fechaAprobacion DateTime? @map("fecha_aprobacion")
  // Comercio/Proveedor del ticket
  comercio        String?  // Nombre del comercio (extraído por OCR)
  cifComercio     String?  @map("cif_comercio")
  // Tarjeta asociada
  tarjeta         String?  // Últimos 4 dígitos o nombre de la tarjeta
  cuentaBancariaId String? @map("cuenta_bancaria_id")
  // Archivo
  archivoUrl      String?  @map("archivo_url")
  archivoNombre   String?  @map("archivo_nombre")
  oneDriveItemId  String?  @map("onedrive_item_id_gasto") // ID del item en OneDrive
  // OCR
  ocrCompletado   Boolean  @default(false) @map("ocr_completado")
  ocrConfianza    Float?   @map("ocr_confianza")
  datosOcrRaw     String?  @map("datos_ocr_raw") // JSON con datos extraídos
  // Fiscal
  deducibleIva    Boolean  @default(false) @map("deducible_iva")
  baseIva         Float?   @map("base_iva")
  importeIva      Float?   @map("importe_iva")
  tipoIva         Float?   @map("tipo_iva") // Porcentaje IVA (21, 10, 4, 0)
  // Impuesto de Sociedades
  deducibleIS     Boolean  @default(true) @map("deducible_is")
  categoriaIS     String?  @map("categoria_is") // Categoría para IS
  // Estado
  estado          EstadoGasto @default(PENDIENTE)
  conciliado      Boolean  @default(false)
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  movimientos     MovimientoBancario[]

  @@index([tipo])
  @@index([fecha])
  @@index([departamento])
  @@index([empleadoId])
  @@index([estado])
  @@map("gastos")
}

model ReglaImputacion {
  id          String   @id @default(uuid())
  patron      String   // Texto o regex que matchea con el concepto del movimiento
  banco       String?  // Si es específica de un banco
  imputacion  String   // Categoría de imputación
  tipoPago    String?  @map("tipo_pago")
  clienteId   String?  @map("cliente_id")
  confianza   Float    @default(0.5) // 0-1, sube con cada uso confirmado
  vecesUsada  Int      @default(0) @map("veces_usada")
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([patron])
  @@index([imputacion])
  @@map("reglas_imputacion")
}

model CompraMaterial {
  id              String   @id @default(uuid())
  proveedor       String
  descripcion     String
  importe         Float
  fecha           DateTime
  garantiaHasta   DateTime? @map("garantia_hasta")
  numFactura      String?  @map("num_factura")
  archivoUrl      String?  @map("archivo_url")
  archivoOneDrive String?  @map("archivo_onedrive")
  estado          EstadoCompraMaterial @default(ACTIVA)
  notas           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([proveedor])
  @@index([garantiaHasta])
  @@map("compras_materiales")
}

enum EstadoFactura {
  PENDIENTE_REVISION
  VALIDADA
  CONTABILIZADA
  RECHAZADA
}

enum TipoGasto {
  GASTO_GENERAL
  DIETA
  DESPLAZAMIENTO
  MATERIAL
  SUSCRIPCION
  PERSONAL
  COMBUSTIBLE
  PARKING
  PEAJE
  MATERIAL_OFICINA
  SUMINISTROS
  COMIDA
  ALOJAMIENTO
  FORMACION
  HERRAMIENTAS
  OTROS
}

enum EstadoGasto {
  PENDIENTE
  PENDIENTE_APROBACION
  APROBADO
  RECHAZADO
  CONTABILIZADO
}

enum MetodoPagoGasto {
  DINERO_PROPIO
  TARJETA_EMPRESA
}

enum EstadoCompraMaterial {
  ACTIVA
  GARANTIA_VENCIDA
  DEVUELTA
}

enum EstadoFacturaEmitida {
  EMITIDA
  ENVIADA
  COBRADA_PARCIAL
  COBRADA
  IMPAGADA
  ANULADA
}

model FacturaEmitida {
  id              String   @id @default(uuid())
  cliente         String   // Nombre del cliente
  cif             String?  // CIF/NIF del cliente
  numFactura      String   @map("num_factura") // Ej: CLL26/1234
  serie           String?  // Serie de facturación (CLL, INST, etc.)
  fecha           DateTime
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  // Importes
  base            Float    // Base imponible
  tipoIva         Float    @default(21) @map("tipo_iva")
  importeIva      Float    @map("importe_iva")
  tipoIrpf        Float    @default(0) @map("tipo_irpf")
  importeIrpf     Float    @default(0) @map("importe_irpf")
  total           Float
  // Detalle
  concepto        String?  // Descripción/concepto de la factura
  lineas          String?  // JSON con líneas de detalle
  // Clasificación
  estado          EstadoFacturaEmitida @default(EMITIDA)
  imputacion      String?  // Estructura, Operadora, Draxton, Vola, etc.
  formaCobro      String?  @map("forma_cobro") // Remesa, Transferencia, Confirming, Efectivo
  // Cobro
  importeCobrado  Float    @default(0) @map("importe_cobrado")
  fechaCobro      DateTime? @map("fecha_cobro")
  // Remesa
  remesaRef       String?  @map("remesa_ref") // Referencia de remesa SEPA
  // Origen
  origenSistema   String?  @map("origen_sistema") // ISPGestion, Manual, etc.
  idExterno       String?  @unique @map("id_externo") // ID en sistema externo
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  movimientosBancarios MovimientoBancario[]
  confirmingLineas ConfirmingLinea[]

  @@index([cliente])
  @@index([estado])
  @@index([fecha])
  @@index([imputacion])
  @@index([serie])
  @@map("facturas_emitidas")
}

// Categorías de imputación predefinidas + ampliables
model CategoriaImputacion {
  id          String   @id @default(uuid())
  nombre      String   @unique // "Estructura", "Operadora", "Cliente (Ventas)", etc.
  descripcion String?
  color       String?  // Color para UI
  tipo        String   @default("gasto") // "gasto", "cliente", "financiero"
  activa      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("categorias_imputacion")
}

// Vinculación entre factura recibida y factura(s) emitida(s) para analítica de rentabilidad
model VinculacionFactura {
  id                String   @id @default(uuid())
  facturaRecibidaId String   @map("factura_recibida_id")
  facturaEmitidaId  String   @map("factura_emitida_id")
  porcentaje        Float    @default(100) // % del coste imputado a esta factura emitida
  notas             String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([facturaRecibidaId, facturaEmitidaId])
  @@index([facturaRecibidaId])
  @@index([facturaEmitidaId])
  @@map("vinculaciones_facturas")
}

// Reglas de imputación automática por proveedor (para auto-clasificar futuras facturas)
model ReglaImputacionProveedor {
  id            String   @id @default(uuid())
  proveedorCif  String?  @map("proveedor_cif") // CIF del proveedor
  proveedorNombre String @map("proveedor_nombre") // Nombre (para matching fuzzy)
  categoriaId   String   @map("categoria_id") // ID de CategoriaImputacion
  categoria     String   // Nombre de la categoría (desnormalizado para rapidez)
  clienteNombre String?  @map("cliente_nombre") // Si es "Cliente (Ventas)", el nombre del cliente
  activa        Boolean  @default(true)
  vecesAplicada Int      @default(1) @map("veces_aplicada")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([proveedorCif])
  @@index([proveedorNombre])
  @@map("reglas_imputacion_proveedor")
}


// Imputación de costes a clientes (desde facturas de proveedores)
model ImputacionCosteCliente {
  id              String   @id @default(uuid())
  facturaId       String   @map("factura_id")
  clienteId       Int      @map("cliente_id")
  clienteNombre   String   @map("cliente_nombre")
  importe         Float    // Importe neto imputado a este cliente
  concepto        String?  // Descripción resumida de las líneas
  numLineas       Int      @default(1) @map("num_lineas") // Cuántas líneas se imputaron
  // Estado
  confirmado      Boolean  @default(true) // Si fue confirmado manualmente
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([facturaId])
  @@index([clienteId])
  @@index([createdAt])
  @@map("imputaciones_coste_cliente")
}

// ============================================================
// MÓDULO DE EMPLEADOS Y RENTABILIDAD
// ============================================================

enum EstadoEmpleado {
  ACTIVO
  BAJA
  EXCEDENCIA
}

enum EstadoProyecto {
  ACTIVO
  PAUSADO
  FINALIZADO
  CANCELADO
}

model Empleado {
  id                String          @id @default(uuid())
  codigoNomina      String?         @unique @map("codigo_nomina") // Código de la gestoría (000004, etc.)
  nombreCompleto    String          @map("nombre_completo")
  nif               String          @unique
  email             String?         @unique
  departamento      String?
  categoria         String?         // GERENTE, COMERCIAL, TÉCNICO, etc.
  fechaAlta         DateTime?       @map("fecha_alta") @db.Date
  fechaBaja         DateTime?       @map("fecha_baja") @db.Date
  estado            EstadoEmpleado  @default(ACTIVO)
  numAfiliacionSS   String?         @map("num_afiliacion_ss")
  tarifaCotizacion  Int?            @map("tarifa_cotizacion")
  costeHoraActual   Float?          @map("coste_hora_actual") // Calculado: costeTotalEmpresa / horas_mes
  // Relaciones
  nominas           Nomina[]
  imputaciones      ImputacionHoras[]
  asignaciones      AsignacionProyecto[]
  calendario        CalendarioPersonal[]
  saldoVacaciones   SaldoVacaciones[]
  entregasACuenta   MovimientoBancario[] @relation("EntregasCuentaEmpleado")
  guardiaTecnicos   GuardiaTecnico[]
  personalContratos PersonalContratoDraxton[] @relation("PersonalContratoDraxton")
  proyectosDraxton   ProyectoContratoDraxton[] @relation("ProyectoResponsable")
  // Timestamps
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([estado])
  @@index([email])
  @@map("empleados")
}

model Nomina {
  id                      String   @id @default(uuid())
  empleadoId              String   @map("empleado_id")
  mes                     Int      // 1-12
  anio                    Int      // 2026, etc.
  // Devengos
  salarioBase             Float?   @map("salario_base")
  devengadoTotal          Float    @map("devengado_total")
  complementoEspecie      Float?   @map("complemento_especie") // Salario en especie
  gastosDesplazamiento    Float?   @map("gastos_desplazamiento")
  // Deducciones trabajador
  irpf                    Float?   // Retención IRPF (valor absoluto)
  porcentajeIrpf          Float?   @map("porcentaje_irpf") // % IRPF
  ssTrabajador            Float?   @map("ss_trabajador") // Cuota SS trabajador
  // Neto
  netoPercibir            Float    @map("neto_percibir") // Líquido a percibir
  // Bases
  baseIrpf                Float?   @map("base_irpf")
  baseSS                  Float?   @map("base_ss")
  // Costes empresa
  ssEmpresa               Float?   @map("ss_empresa") // Cuota SS empresa
  ssTCI                   Float?   @map("ss_tci") // SS Total Coste Integrado
  costeTotalEmpresa       Float?   @map("coste_total_empresa") // Devengado + SS Empresa
  // Archivo
  archivoUrl              String?  @map("archivo_url") // URL del PDF de la nómina
  archivoNombre           String?  @map("archivo_nombre")
  // Relaciones
  empleado                Empleado @relation(fields: [empleadoId], references: [id])
  movimientos             MovimientoBancario[]
  // Timestamps
  createdAt               DateTime @default(now()) @map("created_at")

  @@unique([empleadoId, mes, anio])
  @@index([anio, mes])
  @@map("nominas")
}

model Proyecto {
  id              String           @id @default(uuid())
  nombre          String
  codigo          String?          @unique // Código corto del proyecto (ej: PRJ-001)
  clienteNombre   String?          @map("cliente_nombre")
  clienteId       Int?             @map("cliente_id") // Relación opcional con ClienteWeb
  descripcion     String?
  presupuesto     Float?           // Presupuesto total del proyecto
  estado          EstadoProyecto   @default(ACTIVO)
  fechaInicio     DateTime?        @map("fecha_inicio") @db.Date
  fechaFin        DateTime?        @map("fecha_fin") @db.Date
  // Relaciones
  imputaciones    ImputacionHoras[]
  asignaciones    AsignacionProyecto[]
  // Timestamps
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([estado])
  @@map("proyectos")
}

model AsignacionProyecto {
  id          String   @id @default(uuid())
  empleadoId  String   @map("empleado_id")
  proyectoId  String   @map("proyecto_id")
  rol         String?  // Rol del empleado en el proyecto
  porcentaje  Float?   @default(100) // % de dedicación estimada
  fechaInicio DateTime? @map("fecha_inicio") @db.Date
  fechaFin    DateTime? @map("fecha_fin") @db.Date
  activa      Boolean  @default(true)
  // Relaciones
  empleado    Empleado @relation(fields: [empleadoId], references: [id])
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id])
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([empleadoId, proyectoId])
  @@index([proyectoId])
  @@map("asignaciones_proyecto")
}

model ImputacionHoras {
  id              String   @id @default(uuid())
  empleadoId      String   @map("empleado_id")
  proyectoId      String   @map("proyecto_id")
  fecha           DateTime @db.Date
  horas           Float
  descripcion     String?
  costeImputado   Float?   @map("coste_imputado") // horas × costeHora del empleado
  // Relaciones
  empleado        Empleado @relation(fields: [empleadoId], references: [id])
  proyecto        Proyecto @relation(fields: [proyectoId], references: [id])
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([empleadoId, fecha])
  @@index([proyectoId, fecha])
  @@index([fecha])
  @@map("imputaciones_horas")
}

