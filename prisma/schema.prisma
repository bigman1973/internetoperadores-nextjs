  dni                   String?
  
  // Datos empresa
  razonSocial           String?             @map("razon_social")
  cif                   String?
  nombreApoderado       String?             @map("nombre_apoderado")
  dniApoderado          String?             @map("dni_apoderado")
  
  // Datos comunes
  email                 String
  telefono              String?
  
  // Dirección facturación
  direccionFacturacion  String              @map("direccion_facturacion")
  localidadFacturacion  String              @map("localidad_facturacion")
  provinciaFacturacion  String              @map("provincia_facturacion")
  cpFacturacion         String              @map("cp_facturacion")
  
  // Dirección instalación (puede ser diferente)
  direccionInstalacion  String?             @map("direccion_instalacion")
  localidadInstalacion  String?             @map("localidad_instalacion")
  provinciaInstalacion  String?             @map("provincia_instalacion")
  cpInstalacion         String?             @map("cp_instalacion")
  
  // Método de pago recurrente
  metodoPago            MetodoPagoRecurrente @map("metodo_pago")
  iban                  String?             // Solo si es SEPA
  
  // Pago cuota de alta (si aplica)
  pagoAltaGateway       PaymentGateway?     @map("pago_alta_gateway")
  pagoAltaStatus        PaymentStatus?      @map("pago_alta_status")
  pagoAltaUrl           String?             @map("pago_alta_url")
  pagoAltaTransactionId String?             @map("pago_alta_transaction_id")
  
  // Tarifa contratada
  tarifaId              Int                 @map("tarifa_id")
  tarifaNombre          String              @map("tarifa_nombre")
  importeCuota          Decimal             @map("importe_cuota") @db.Decimal(10, 2)
  importeAlta           Decimal?            @map("importe_alta") @db.Decimal(10, 2)
  permanencia           String?
  
  // Portabilidad
  esPortabilidad        Boolean             @default(false) @map("es_portabilidad")
  numeroPortar          String?             @map("numero_portar")
  operadorActual        String?             @map("operador_actual")
